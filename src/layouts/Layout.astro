---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookingButton from '../components/BookingButton.astro';
import PerformanceOptimizer from '../components/PerformanceOptimizer.astro';
import EasterEggManager from '../components/EasterEggManager';
import DesktopEnhancements from '../components/DesktopEnhancements.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: string;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  performanceMode?: 'default' | 'light';
  showBookingButton?: boolean;
}

const canonicalUrl = `https://www.delco-ink.fr${Astro.url.pathname.replace(/\/$/, '') || '/'}`;
const { 
  title, 
  description = "Tatouage Chambéry & Cognin · Delco Ink, spécialiste blackwork illustratif et pop-culture. Salon privé Studio Ensō, sur rendez-vous. Réalisations uniques, hygiène parfaite.",
  canonical = canonicalUrl,
  image = "https://www.delco-ink.fr/images/delco-ink-studio-tatouage-chambery-hero.webp",
  type = "website",
  publishedTime,
  modifiedTime,
  author = "Delco Ink",
  performanceMode = 'default',
  showBookingButton = true
} = Astro.props;

const siteName = "Delco Ink - Tatouage Chambéry";
const twitterHandle = "@delco_ink";
const isHomePage = Astro.url.pathname === '/';
const isLightPage = performanceMode === 'light';
---

<!doctype html>
<html lang="fr" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    
    <!-- SEO Essentials -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="bingbot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    
    <!-- Language & Region -->
    <meta name="language" content="French" />
    <meta name="geo.region" content="FR-73" />
    <meta name="geo.placename" content="Chambéry, Cognin, Savoie" />
    <meta name="geo.position" content="45.5667;5.9167" />
    <meta name="ICBM" content="45.5667, 5.9167" />
    <link rel="alternate" hreflang="fr" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    
    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Delco Ink - Tatouage Chambéry" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="fr_FR" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {type === "article" && <meta property="article:author" content={author} />}
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterHandle} />
    <meta name="twitter:creator" content={twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content="Delco Ink - Tatouage Chambéry" />
    
    <!-- Favicon & Icons -->
    <link rel="icon" type="image/png" sizes="180x180" href="/favicon-180x180.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180x180.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-180x180.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-180x180.png" />
    <meta name="theme-color" content="#2d6a4f" />
    <meta name="msapplication-TileColor" content="#2d6a4f" />
    
    <!-- Preconnect & DNS Prefetch -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.instagram.com" />
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />
    
    <!-- Google Fonts - chargement async non-bloquant -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Caveat+Brush&family=Lato:wght@300;400;700&family=Quicksand:wght@400;500;600;700&family=Satisfy&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Caveat+Brush&family=Lato:wght@300;400;700&family=Quicksand:wght@400;500;600;700&family=Satisfy&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Caveat+Brush&family=Lato:wght@300;400;700&family=Quicksand:wght@400;500;600;700&family=Satisfy&display=swap" /></noscript>
    
    <!-- Preload Critical Resources -->
    {isHomePage && <link rel="preload" as="image" href="/images/delco-ink-studio-tatouage-chambery-hero-mobile.webp" imagesrcset="/images/delco-ink-studio-tatouage-chambery-hero-mobile.webp 768w, /images/delco-ink-studio-tatouage-chambery-hero-tablet.webp 1280w, /images/delco-ink-studio-tatouage-chambery-hero.webp 1920w" imagesizes="100vw" fetchpriority="high" />}
    {isHomePage && <link rel="preload" as="image" href="/img/Logo-hero-mobile.webp" imagesrcset="/img/Logo-hero-mobile.webp 180w, /img/Logo-hero.webp 320w" imagesizes="(max-width: 768px) 160px, 320px" fetchpriority="high" />}
    
    <!-- Schema.org Organization -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Delco Ink",
      "alternateName": ["Studio Delco Ink"],
      "url": "https://www.delco-ink.fr",
      "logo": "https://www.delco-ink.fr/img/Logo.webp",
      "sameAs": [
        "https://www.instagram.com/delco.ink/",
        "https://www.tiktok.com/@delco_ink"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "areaServed": "FR",
        "availableLanguage": "French"
      }
    }
    </script>
    
    <!-- Slot for additional head content (e.g., noindex) -->
    <slot name="head" />
  </head>
  <body class="flex flex-col min-h-screen texture-overlay texture-paper">
    {!isLightPage && <PerformanceOptimizer />}
    <Header />
    
    <main class="flex-grow pt-16" role="main">
      <slot />
    </main>
    
    {showBookingButton && <BookingButton />}
    <Footer />
    {!isLightPage && <EasterEggManager client:media="(min-width: 769px)" />}
    {!isLightPage && <DesktopEnhancements />}
  </body>
</html>
