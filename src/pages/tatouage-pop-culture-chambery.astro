        "url": "https://www.delco-ink.fr/tatouage-pop-culture-chambery"
      },
      {
        "@type": "Service",
        "name": "Tatouage Pop-Culture Chambéry",
        "description": "Tatouages pop-culture en blackwork illustratif : manga, anime, jeux vidéo, films, séries à Chambéry/Cognin.",
        "provider": {
          "@type": "Person",
