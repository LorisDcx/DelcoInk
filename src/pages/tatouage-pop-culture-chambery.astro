            }
          }
        },
        "areaServed": ["Chambéry", "Cognin", "Grand Chambéry", "Savoie"]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Est-ce qu'un tatouage pop-culture peut être fait en blackwork ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Oui, le blackwork est idéal pour les tatouages pop-culture. Les contrastes marqués et les aplats noirs rendent les personnages reconnaissables et durent dans le temps mieux que la couleur."
            }
          },
          {
            "@type": "Question",
