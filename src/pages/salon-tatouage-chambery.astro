---
import Layout from '../layouts/Layout.astro';
import InternalLinks from '../components/InternalLinks.astro';
---

<Layout 
  title="Salon de Tatouage Chambéry | Studio Ensō - Delco Ink"
  description="Salon de tatouage à Chambéry (Cognin) : Studio Ensō, tatouage blackwork illustratif et pop-culture sur rendez-vous. Espace privé, hygiène irréprochable, artiste dédiée."
  canonical="https://www.delco-ink.fr/salon-tatouage-chambery"
>
  <!-- Hero -->
  <section class="relative pt-28 pb-16 overflow-hidden" style="background: linear-gradient(160deg, #f8f5ee 0%, #f0ece0 50%, #e8e3d5 100%);">
    <div class="absolute inset-0 opacity-5 texture-paper pointer-events-none"></div>
    <div class="absolute top-10 right-8 w-36 h-36 opacity-8 floating-slow hidden md:block">
      <img src="/img/monstera.webp" alt="" class="w-full h-full object-contain" width="144" height="144" loading="eager" decoding="async" />
    </div>
    <div class="container mx-auto px-4 text-center relative z-10">
      <p class="text-forest text-sm font-medium uppercase tracking-widest mb-5 font-quicksand">
        Delco Ink — <a href="/specialites" class="hover:underline">Spécialités</a>
      </p>
      <h1 class="font-title text-5xl md:text-6xl text-gray-900 mb-6 relative inline-block transform -rotate-[0.5deg]">
        Salon de Tatouage
        <span class="block text-2xl md:text-3xl text-forest font-satisfy mt-2 transform rotate-[-0.5deg]">Chambéry · Studio Ensō</span>
      </h1>
      <p class="text-gray-600 text-lg max-w-xl mx-auto font-quicksand leading-relaxed mb-8">
        Espace privé à Cognin, 5 minutes de Chambéry.<br/>Sur rendez-vous uniquement — hygiène irréprochable.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/#contact-anchor" class="inline-flex items-center gap-2 px-6 py-3 bg-forest text-white rounded-full font-medium hover:bg-forest/90 transition-all font-quicksand">
          Prendre rendez-vous
        </a>
        <a href="/le-studio" class="inline-flex items-center gap-2 px-6 py-3 bg-white/80 text-forest rounded-full font-medium border border-forest/20 hover:bg-white transition-all font-quicksand">
          Découvrir le studio
        </a>
      </div>
    </div>
  </section>

  <article class="seo-article py-16" itemscope itemtype="https://schema.org/Article">
    <div class="container mx-auto px-4 max-w-4xl">

      <div class="seo-body space-y-12" itemprop="articleBody">

        <!-- Présentation -->
        <section>
          <h2 class="font-title text-2xl text-gray-800 mb-4">Un salon de tatouage pas comme les autres</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Vous cherchez un <strong>salon de tatouage à Chambéry</strong> qui sort du modèle traditionnel ? 
            Studio Ensō est un espace privé et chaleureux, pensé pour accueillir les clients dans les meilleures 
            conditions possibles. Pas de passage, pas de bruit de fond, pas de file d'attente : chaque rendez-vous 
            est dédié à un seul projet, avec une attention totale.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            Chloé, tatoueuse spécialisée en <a href="/blackwork-chambery" class="text-forest underline">blackwork illustratif</a> 
            et <a href="/tatouage-pop-culture-chambery" class="text-forest underline">pop-culture</a>, y reçoit ses 
            clients sur rendez-vous uniquement. Cette organisation permet de consacrer tout le temps nécessaire 
            à chaque projet, de la consultation jusqu'à la finition.
          </p>
          <p class="text-gray-600 leading-relaxed">
            Le studio est équipé de matériel professionnel et respecte les normes d'hygiène en vigueur : 
            aiguilles à usage unique, surfaces stérilisées, encres certifiées. Votre sécurité et votre confort 
            sont les priorités absolues.
          </p>
        </section>

        <!-- Pourquoi choisir ce salon -->
        <section>
          <h2 class="font-title text-2xl text-gray-800 mb-6">Pourquoi choisir le Studio Ensō ?</h2>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="p-5 bg-white rounded-xl shadow-sm border border-gray-100 flex items-start gap-4">
              <span class="flex-shrink-0 w-10 h-10 bg-forest/10 rounded-full flex items-center justify-center text-forest font-bold">🎨</span>
              <div>
                <h3 class="font-semibold text-gray-800 mb-1">Spécialisation artistique</h3>
                <p class="text-gray-600 text-sm">Un seul style maîtrisé à la perfection : le blackwork illustratif. Pas de généraliste — une artiste dédiée qui excelle dans ce qu'elle fait.</p>
              </div>
            </div>
            <div class="p-5 bg-white rounded-xl shadow-sm border border-gray-100 flex items-start gap-4">
              <span class="flex-shrink-0 w-10 h-10 bg-forest/10 rounded-full flex items-center justify-center text-forest font-bold">🔒</span>
              <div>
                <h3 class="font-semibold text-gray-800 mb-1">Espace privé et serein</h3>
                <p class="text-gray-600 text-sm">Salon privatisé pour chaque séance. Vous ne faites pas la queue et vous n'êtes pas entouré de bruit. L'ambiance est calme et bienveillante.</p>
              </div>
            </div>
            <div class="p-5 bg-white rounded-xl shadow-sm border border-gray-100 flex items-start gap-4">
              <span class="flex-shrink-0 w-10 h-10 bg-forest/10 rounded-full flex items-center justify-center text-forest font-bold">✓</span>
              <div>
                <h3 class="font-semibold text-gray-800 mb-1">Hygiène irréprochable</h3>
                <p class="text-gray-600 text-sm">Normes d'hygiène strictes : matériel stérile, aiguilles à usage unique, surfaces désinfectées systématiquement entre chaque client.</p>
              </div>
            </div>
            <div class="p-5 bg-white rounded-xl shadow-sm border border-gray-100 flex items-start gap-4">
              <span class="flex-shrink-0 w-10 h-10 bg-forest/10 rounded-full flex items-center justify-center text-forest font-bold">💬</span>
              <div>
                <h3 class="font-semibold text-gray-800 mb-1">Consultation sur mesure</h3>
                <p class="text-gray-600 text-sm">Chaque projet démarre par un échange approfondi : votre idée, la zone, la taille, vos attentes. Le devis final arrive après cet entretien.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Accès et infos pratiques -->
        <section>
          <h2 class="font-title text-2xl text-gray-800 mb-4">Accès et informations pratiques</h2>
          <div class="bg-gray-50 p-6 rounded-xl space-y-5" itemscope itemtype="https://schema.org/TattooParlor">
            <div class="flex items-start gap-4">
              <span class="text-forest text-xl">📍</span>
              <div itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
                <p class="font-semibold text-gray-800">Adresse du salon</p>
                <p class="text-gray-600">
                  <span itemprop="streetAddress">19 Av. Général Cartier</span><br>
                  <span itemprop="postalCode">73160</span> <span itemprop="addressLocality">Cognin</span> 
                  (<abbr title="Chambéry">Chambéry</abbr>), <span itemprop="addressRegion">Savoie</span>
                </p>
                <p class="text-gray-500 text-sm mt-1">Parking gratuit à proximité · 5 min du centre de Chambéry</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="text-forest text-xl">🕐</span>
              <div itemprop="openingHoursSpecification" itemscope itemtype="https://schema.org/OpeningHoursSpecification">
                <p class="font-semibold text-gray-800">Horaires d'ouverture</p>
                <div class="text-gray-600 space-y-1 mt-1">
                  <p>Lundi – Mercredi : <strong>9h00 – 19h00</strong></p>
                  <p>Jeudi – Samedi : <span class="text-gray-400">Fermé</span></p>
                  <p>Dimanche : <strong>13h00 – 19h00</strong></p>
                </div>
                <p class="text-forest text-sm font-medium mt-2">Sur rendez-vous uniquement</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="text-forest text-xl">📩</span>
              <div>
                <p class="font-semibold text-gray-800">Prise de rendez-vous</p>
                <p class="text-gray-600">Via Instagram <a href="https://www.instagram.com/delco.ink/" class="text-forest underline" target="_blank" rel="noopener noreferrer">@delco.ink</a> ou via le <a href="/#contact-anchor" class="text-forest underline">formulaire de contact</a>.</p>
                <p class="text-gray-500 text-sm mt-1">Délai de réponse habituel : 24 à 48h</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="text-forest text-xl">💶</span>
              <div>
                <p class="font-semibold text-gray-800">Tarifs</p>
                <p class="text-gray-600">Sur devis selon taille et complexité. Acompte de 20 % à la réservation.</p>
                <p class="text-gray-500 text-sm mt-1">Consultation et devis : gratuits et sans engagement</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Styles proposés dans ce salon -->
        <section>
          <h2 class="font-title text-2xl text-gray-800 mb-4">Styles de tatouage proposés au Studio Ensō</h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            Le Studio Ensō se spécialise dans deux grandes familles complémentaires :
          </p>
          <div class="space-y-4">
            <div class="p-5 bg-white rounded-xl border border-forest/20">
              <h3 class="font-title text-lg text-forest mb-2">Blackwork illustratif</h3>
              <p class="text-gray-600 text-sm">
                Style en noir profond, lignes maîtrisées, compositions graphiques. Idéal pour les designs géométriques, 
                botaniques, animaliers ou typographiques. Le blackwork est le style le plus durable qui soit — 
                l'encre noire vieillit mieux que toute autre couleur. 
                <a href="/blackwork-chambery" class="text-forest underline">En savoir plus sur le blackwork</a>.
              </p>
            </div>
            <div class="p-5 bg-white rounded-xl border border-forest/20">
              <h3 class="font-title text-lg text-forest mb-2">Pop-culture & Manga</h3>
              <p class="text-gray-600 text-sm">
                Adaptation d'univers audiovisuels, vidéoludiques et manga en blackwork. Personnages iconiques, 
                mashups créatifs, compositions narratives. Une spécialité unique en Savoie. 
                <a href="/tatouage-pop-culture-chambery" class="text-forest underline">Voir la page pop-culture</a>.
              </p>
            </div>
            <div class="p-5 bg-white rounded-xl border border-forest/20">
              <h3 class="font-title text-lg text-forest mb-2">Flash Tattoos</h3>
              <p class="text-gray-600 text-sm">
                Designs prêts à tatouer, créés à l'avance, à prix fixe. Disponibles pour réservation immédiate. 
                Collection régulièrement renouvelée. 
                <a href="/flash" class="text-forest underline">Voir les flash disponibles</a>.
              </p>
            </div>
          </div>
        </section>

        <!-- Zone géographique -->
        <section>
          <h2 class="font-title text-2xl text-gray-800 mb-4">Zone de clientèle — Qui vient au Studio Ensō ?</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Bien que le studio soit situé à <strong>Cognin</strong>, il accueille des clients de toute 
            l'agglomération chambérienne et du département de la Savoie :
          </p>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
            <div class="text-center p-3 bg-gray-50 rounded-lg text-sm text-gray-600"><strong>Chambéry</strong> · 5 min</div>
            <div class="text-center p-3 bg-gray-50 rounded-lg text-sm text-gray-600"><strong>Aix-les-Bains</strong> · 25 min</div>
            <div class="text-center p-3 bg-gray-50 rounded-lg text-sm text-gray-600"><strong>Albertville</strong> · 40 min</div>
            <div class="text-center p-3 bg-gray-50 rounded-lg text-sm text-gray-600"><strong>La Motte-Servolex</strong> · 10 min</div>
            <div class="text-center p-3 bg-gray-50 rounded-lg text-sm text-gray-600"><strong>Saint-Alban-Leysse</strong> · 10 min</div>
            <div class="text-center p-3 bg-gray-50 rounded-lg text-sm text-gray-600"><strong>Montmélian</strong> · 20 min</div>
          </div>
        </section>

        <!-- CTA -->
        <section class="text-center bg-forest/5 p-8 rounded-xl">
          <h2 class="font-title text-2xl text-gray-800 mb-4">Prenez rendez-vous dans notre salon à Chambéry</h2>
          <p class="text-gray-600 mb-6 max-w-xl mx-auto">
            Consultez le portfolio, discutez de votre projet et réservez votre séance. 
            Réponse sous 48h.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/#contact-anchor" class="inline-block px-8 py-3 bg-forest text-white font-medium rounded-full hover:bg-forest/90 transition-colors">
              Prendre rendez-vous
            </a>
            <a href="/#gallery" class="inline-block px-8 py-3 border border-forest text-forest font-medium rounded-full hover:bg-forest/5 transition-colors">
              Voir les réalisations
            </a>
          </div>
        </section>
      </div>

      <div class="mt-12">
        <a href="/" class="text-forest font-medium hover:underline">← Retour à l'accueil</a>
      </div>

      <InternalLinks currentPage="/salon-tatouage-chambery" />
    </div>
  </article>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "TattooParlor",
    "name": "Studio Ensō — Delco Ink",
    "description": "Salon de tatouage privé à Cognin (Chambéry). Spécialité blackwork illustratif et pop-culture. Sur rendez-vous uniquement.",
    "url": "https://www.delco-ink.fr/salon-tatouage-chambery",
    "image": "https://www.delco-ink.fr/images/studio-enso-tatoueur-cognin-chambery.webp",
    "telephone": "",
    "email": "contact@delco-ink.fr",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "19 Av. Général Cartier",
      "addressLocality": "Cognin",
      "addressRegion": "Savoie",
      "postalCode": "73160",
      "addressCountry": "FR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 45.5667,
      "longitude": 5.9167
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday"],
        "opens": "09:00",
        "closes": "19:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Sunday"],
        "opens": "13:00",
        "closes": "19:00"
      }
    ],
    "sameAs": [
      "https://www.instagram.com/delco.ink/",
      "https://www.tiktok.com/@delco_ink"
    ]
  }
  </script>
</Layout>
